* text=auto
.gitattributes text eol=lf

# Cross-platform source and automation must remain executable on Linux checkouts.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.spec text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Native Windows command scripts use Windows line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.iss text eol=crlf
*.ps1 text eol=crlf

# Do not perform newline conversion on packaged or visual assets.
*.AppImage binary
*.deb binary
*.exe binary
*.gz binary
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.pyd binary
*.so binary
*.zip binary
